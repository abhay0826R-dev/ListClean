{
    "name" : "InternShield",
    "description" : "blacklist job internships you don't wanna see! easily through extension popup",
    "version" : "1.0",
    "manifest_version" : 3,
    "icons" : {
        "16" : "./images/icon/16.png",
        "32" : "./images/icon/32.png",
        "48" : "./images/icon/48.png",
        "128" : "./images/icon/128.png"
    },
    "action" : {
        "default_popup" : "popup/popup.html"
    },
    "permissions" : [
        "scripting",
        "tabs"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "content_scripts": [
    {
        "matches": ["https://internshala.com/internships/*"],
        "js": ["scripts/content.js"]
    }
]

}