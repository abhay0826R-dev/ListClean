{
    "name" : "ListClean",
    "description" : "blacklist job internships you don't wanna see! easily through extension popup",
    "version" : "1.0",
    "manifest_version" : 3,
    "action" : {
        "default_popup" : "popup/popup.html",
        "default_icon" : "images/icon.png"
    },
    "permissions" : [
        "scripting",
        "tabs"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "content_scripts": [
    {
        "matches": ["https://internshala.com/internships/*"],
        "js": ["scripts/content.js"]
    }
]

}